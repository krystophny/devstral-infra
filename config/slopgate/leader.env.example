# Slopgate leader-node configuration. Copy to ~/.config/slopgate/leader.env
# and fill in the placeholder values for THIS host. The real file is
# git-ignored — never commit it.
#
# This is the box that runs the slopgate balancer. It also runs its own
# llama-server on the loopback (the launcher flips to 127.0.0.1:8081 when
# the slopgate-balancer plist/unit is installed) and registers it with the
# balancer through a co-located slopgate-agent.

# --- Balancer (reverse proxy in front of the cluster) -----------------------
SLOPGATE_REVERSEPROXY_ADDR=0.0.0.0:8080
SLOPGATE_MANAGEMENT_ADDR=0.0.0.0:8085
# Web management dashboard at http://<this-host>:8085/dashboard. Loopback or
# private network only — there is no auth.
SLOPGATE_DASHBOARD_ENABLE=true

# Slot overbooking factor. 1.0 = strict 1-request-per-physical-slot (default).
# Above 1.0 lets the admission layer accept more in-flight requests than there
# are physical slots; the proxy still serialises them across actual slots.
SLOPGATE_OVERBOOK_FACTOR=1.5

# Resilience tuning. Stale agents drop out of routing after stale-after; they
# are evicted from the registry after evict-after.
SLOPGATE_AGENT_STALE_AFTER=10
SLOPGATE_AGENT_EVICT_AFTER=30

# Default token-output budget when a request omits max_tokens. The KV-headroom
# filter uses input-tokens + this number to decide whether a slot fits.
SLOPGATE_DEFAULT_T_OUT=4096

# Sticky-session affinity (X-Slopgate-Session). LRU capacity / TTL in seconds.
SLOPGATE_SESSION_LRU_CAPACITY=10000
SLOPGATE_SESSION_TTL=1800

# --- Local llama-server agent (this host) -----------------------------------
SLOPGATE_LOCAL_AGENT_NAME=leader
SLOPGATE_LOCAL_LLAMACPP_ADDR=127.0.0.1:8081
SLOPGATE_LOCAL_MAX_CONTEXT=262144
SLOPGATE_LOCAL_MODEL_ALIAS=qwen
# Optional: SLOPGATE_LOCAL_AUDIO_LLAMACPP_ADDR points at the local whisper.cpp
# (default 127.0.0.1:8427). Set this if you want STT to flow through the same
# slopgate balancer port; leave unset to keep whisper direct.
# SLOPGATE_LOCAL_AUDIO_LLAMACPP_ADDR=127.0.0.1:8427
